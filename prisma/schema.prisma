generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(cuid())
  fullName          String
  email             String               @unique
  passwordHash      String
  role              String               @default("STUDENT")
  facultyId         String?
  departmentId      String?
  avatar            String?
  phone             String?
  studentId         String?              @unique
  employeeId        String?              @unique
  status            String               @default("PENDING")
  lastLoginAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  faculty           Faculty?             @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  department        Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  uploadedResources Resource[]           @relation("UploadedResources")
  approvedResources Resource[]           @relation("ApprovedResources")
  reservations      Reservation[]
  loans             Loan[]
  renewalRequests   RenewalRequest[]
  favorites         Favorite[]
  reviews           Review[]
  viewLogs          ViewLog[]
  downloadLogs      DownloadLog[]
  searchLogs        SearchLog[]
  auditLogs         AuditLog[]
  securityLogs      SecurityLog[]
  notifications     Notification[]
  seatReservations  SeatReservation[]
  passwordResets    PasswordResetToken[]
  studentProfile    StudentProfile?
  librarianProfile  LibrarianProfile?

  @@index([role])
  @@index([status])
  @@index([facultyId])
  @@index([departmentId])
}

model Faculty {
  id          String       @id @default(cuid())
  nameUz      String
  nameRu      String
  nameEn      String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  departments Department[]
  users       User[]
  resources   Resource[]
}

model Department {
  id          String       @id @default(cuid())
  facultyId   String
  nameUz      String
  nameRu      String
  nameEn      String
  slug        String       @unique
  code        String?      @unique
  headName    String?
  email       String?
  phone       String?
  room        String?
  description String?
  imageUrl    String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  faculty     Faculty      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  users       User[]
  resources   Resource[]

  @@index([facultyId])
}

model StudentProfile {
  id            String   @id @default(cuid())
  userId         String   @unique
  group          String?
  faculty        String?
  direction      String?
  studentNumber  String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LibrarianProfile {
  id         String   @id @default(cuid())
  userId      String   @unique
  position    String?
  department  String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id            String       @id @default(cuid())
  nameUz        String
  nameRu        String
  nameEn        String
  slug          String       @unique
  icon          String?
  parentId      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  parent        Category?    @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children      Category[]   @relation("CategoryTree")
  resources     Resource[]

  @@index([parentId])
}

model Author {
  id         String           @id @default(cuid())
  fullName   String
  bio        String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  resources  ResourceAuthor[]
}

model Resource {
  id              String           @id @default(cuid())
  title           String
  slug            String           @unique
  description     String
  abstract        String?
  keywords        String?
  categoryId      String
  facultyId       String?
  departmentId    String?
  language        String           @default("UZ")
  publicationYear Int?
  publisher       String?
  isbn            String?
  udk             String?
  bbk             String?
  pages           Int?
  resourceType    String           @default("TEXTBOOK")
  coverImageUrl   String?
  fileUrl         String?
  fileSize        Int?
  fileFormat      String?
  fileChecksum    String?
  accessType      String           @default("PUBLIC")
  status          String           @default("DRAFT")
  viewCount       Int              @default(0)
  downloadCount   Int              @default(0)
  ratingAvg       Float            @default(0)
  ratingCount     Int              @default(0)
  uploadedById    String
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  faculty         Faculty?         @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  department      Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  uploadedBy      User             @relation("UploadedResources", fields: [uploadedById], references: [id], onDelete: Restrict)
  approvedBy      User?            @relation("ApprovedResources", fields: [approvedById], references: [id], onDelete: SetNull)
  authors         ResourceAuthor[]
  copies          BookCopy[]
  reservations    Reservation[]
  loans           Loan[]
  favorites       Favorite[]
  reviews         Review[]
  viewLogs        ViewLog[]
  downloadLogs    DownloadLog[]

  @@index([status])
  @@index([categoryId])
  @@index([facultyId])
  @@index([departmentId])
  @@index([resourceType])
  @@index([language])
  @@index([publicationYear])
  @@index([accessType])
}

model ResourceAuthor {
  resourceId String
  authorId   String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  author     Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([resourceId, authorId])
  @@index([authorId])
}

model BookCopy {
  id              String         @id @default(cuid())
  resourceId      String
  inventoryNumber String         @unique
  barcode         String         @unique
  qrCode          String?
  shelfLocation   String?
  status          String         @default("AVAILABLE")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  resource        Resource       @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  reservations    Reservation[]
  loans           Loan[]

  @@index([resourceId])
  @@index([status])
}

model Reservation {
  id             String            @id @default(cuid())
  userId         String
  resourceId     String
  copyId         String
  pickupDate     DateTime
  pickupDeadline DateTime
  status         String            @default("PENDING")
  librarianNote  String?
  qrCode         String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource       Resource          @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  copy           BookCopy          @relation(fields: [copyId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([resourceId])
  @@index([copyId])
  @@index([status])
  @@index([pickupDate])
}

model Loan {
  id           String     @id @default(cuid())
  userId       String
  resourceId   String
  copyId       String
  issuedAt     DateTime   @default(now())
  dueAt        DateTime
  returnedAt   DateTime?
  status       String     @default("ACTIVE")
  renewalCount Int        @default(0)
  fineAmount   Float      @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource     Resource   @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  copy         BookCopy   @relation(fields: [copyId], references: [id], onDelete: Restrict)
  renewals     RenewalRequest[]

  @@index([userId])
  @@index([resourceId])
  @@index([copyId])
  @@index([status])
  @@index([dueAt])
}

model RenewalRequest {
  id             String        @id @default(cuid())
  loanId         String
  userId         String
  requestedDueAt DateTime
  status         String        @default("PENDING")
  librarianNote  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  loan           Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([userId])
  @@index([status])
}

model ReadingRoom {
  id          String             @id @default(cuid())
  name        String
  floor       String
  capacity    Int
  openingTime String
  closingTime String
  status      String            @default("ACTIVE")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  seats       Seat[]
  bookings    SeatReservation[]
}

model Seat {
  id              String            @id @default(cuid())
  roomId          String
  seatNumber      String
  hasPowerSocket  Boolean           @default(false)
  hasComputer     Boolean           @default(false)
  status          String            @default("AVAILABLE")
  room            ReadingRoom       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  reservations    SeatReservation[]

  @@unique([roomId, seatNumber])
  @@index([roomId])
  @@index([status])
}

model SeatReservation {
  id         String                @id @default(cuid())
  userId     String
  roomId     String
  seatId     String
  startTime  DateTime
  endTime    DateTime
  status     String                @default("BOOKED")
  qrCode     String?
  checkInAt  DateTime?
  checkOutAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  room       ReadingRoom           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  seat       Seat                  @relation(fields: [seatId], references: [id], onDelete: Cascade)

  @@unique([seatId, startTime, endTime])
  @@index([userId])
  @@index([roomId])
  @@index([status])
  @@index([startTime])
  @@index([endTime])
}

model Favorite {
  id         String    @id @default(cuid())
  userId     String
  resourceId String
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

model Review {
  id         String       @id @default(cuid())
  userId     String
  resourceId String
  rating     Int
  comment    String?
  status     String       @default("PENDING")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource     @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

model ViewLog {
  id         String    @id @default(cuid())
  userId     String?
  resourceId String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  resource   Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model DownloadLog {
  id         String    @id @default(cuid())
  userId     String?
  resourceId String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  resource   Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model SearchLog {
  id          String    @id @default(cuid())
  userId      String?
  query       String
  filters     String?
  resultCount Int
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id         String    @id @default(cuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  oldValue   String?
  newValue   String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model SecurityLog {
  id         String           @id @default(cuid())
  userId     String?
  event      String
  severity   String
  ipAddress  String?
  userAgent  String?
  metadata   String?
  createdAt  DateTime         @default(now())
  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([event])
  @@index([severity])
  @@index([createdAt])
}

model Announcement {
  id         String             @id @default(cuid())
  title      String
  content    String
  imageUrl   String?
  status     String             @default("DRAFT")
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model SystemSetting {
  id         String   @id @default(cuid())
  key        String   @unique
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       String           @default("SYSTEM")
  title      String
  message    String
  actionUrl  String?
  priority   String           @default("NORMAL")
  readAt     DateTime?
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([priority])
  @@index([createdAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
