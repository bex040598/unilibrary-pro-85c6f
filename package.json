{
  "name": "atmu-smart-unilibrary-enterprise",
  "version": "0.1.0",
  "private": true,
  "description": "ATMU Smart UniLibrary Enterprise",
  "scripts": {
    "dev": "node scripts/run-next.mjs dev",
    "build": "next build && node scripts/ensure-next-build-id.mjs",
    "start": "node scripts/run-next.mjs start",
    "start:render": "node scripts/render-start.mjs",
    "lint": "eslint . --max-warnings=0",
    "test": "npm run prisma:generate:sqlite && npm run db:seed:sqlite && node scripts/run-vitest.mjs",
    "test:watch": "vitest",
    "prisma:generate": "node scripts/prisma-safe.mjs generate --schema prisma/schema.prisma",
    "prisma:generate:postgres": "node scripts/prisma-safe.mjs generate --schema prisma/schema.prisma",
    "prisma:generate:sqlite": "node scripts/prisma-safe.mjs generate --schema prisma/schema.sqlite.prisma",
    "db:migrate": "npm run prisma:generate:postgres && node scripts/prisma-safe.mjs migrate dev --schema prisma/schema.prisma",
    "db:seed": "npm run prisma:generate:postgres && node scripts/run-seed.mjs postgres",
    "db:reset": "npm run prisma:generate:postgres && node scripts/prisma-safe.mjs migrate reset --force --skip-seed --schema prisma/schema.prisma && npm run db:seed",
    "db:studio": "prisma studio",
    "db:migrate:sqlite": "npm run prisma:generate:sqlite && node scripts/prisma-safe.mjs migrate dev --schema prisma/schema.sqlite.prisma",
    "db:seed:sqlite": "npm run prisma:generate:sqlite && node scripts/prisma-safe.mjs db push --force-reset --skip-generate --schema prisma/schema.sqlite.prisma && node scripts/run-seed.mjs sqlite",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.20.0",
    "bcrypt": "^5.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^5.9.3",
    "lucide-react": "^0.462.0",
    "next": "^15.0.3",
    "next-themes": "^0.4.3",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "recharts": "^2.13.3",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.15",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
